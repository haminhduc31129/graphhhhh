\frametitle{Solution - Bài 3}

    \begin{block}{Ý tưởng}
        \begin{itemize}
            \item Khi DFS từ $u$ sang $v$
            \item Nếu $v$ đã thăm và $v \neq parent[u]$ → có chu trình
        \end{itemize}
    \end{block}
