\frametitle{Mã mẫu BFS}

\textbf{Cài đặt BFS bằng hàng đợi (C++)}

\begin{verbatim}
vector<int> adj[N];bool visited[N];
void bfs(int s){
    queue<int> q;visited[s] = true;
    q.push(s);
    while(!q.empty()){
        int u = q.front();
        q.pop();
        cout << u << " ";
        for(int v : adj[u])if(!visited[v]){
            visited[v] = true;
            q.push(v);
        }
    }
}
\end{verbatim}

